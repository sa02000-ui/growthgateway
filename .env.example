# ---------------------------------------------------------------------------
# Environment variables for the Personality & Growth Portal.
#
# Copy this file to `.env` and fill in real values (or set these in your host's
# secret manager — Replit Secrets, Vercel/Render/Railway env vars, GitHub Actions
# secrets, etc.). `.env` is gitignored; this template is committed so any tool or
# environment can reproduce the setup. NEVER put real secrets in this file.
# ---------------------------------------------------------------------------

# === Supabase (auth + primary data) ========================================
# Project URL, e.g. https://xxxxxxxxxxxx.supabase.co
SUPABASE_URL=https://your-project-ref.supabase.co

# ANON / publishable key. SAFE to expose to the browser — it is served to the
# frontend via GET /api/config and is governed by Row Level Security.
# Must be the anon key, NOT the service role key.
SUPABASE_KEY=your-anon-publishable-key

# SERVICE ROLE / secret key. SERVER-ONLY. Bypasses Row Level Security — never
# send this to the browser and never expose it publicly.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# === Database (Postgres) ====================================================
# Direct Postgres connection string used by the pg client (profiles, life
# events, profile history, shared_results) and by drizzle-kit (db:push).
# TODAY this points at the Replit-managed Postgres. INDEPENDENCE GOAL: repoint
# this at the Supabase Postgres connection string so there is a single database:
#   postgresql://postgres:[PASSWORD]@db.your-project-ref.supabase.co:5432/postgres
DATABASE_URL=postgresql://user:password@host:5432/dbname

# === AI (OpenAI-compatible, for AI growth insights) =========================
AI_INTEGRATIONS_OPENAI_API_KEY=your-openai-api-key
# Optional: custom base URL for an OpenAI-compatible endpoint. Leave unset for
# the default OpenAI API.
AI_INTEGRATIONS_OPENAI_BASE_URL=

# === Email (SendGrid, for peer-feedback invites) ============================
# Without these, invite links are still generated but not auto-emailed.
SENDGRID_API_KEY=your-sendgrid-api-key
# Verified sender address shown as the "from" on invite emails.
INVITE_FROM_EMAIL=you@yourdomain.com
# Fallback sender if INVITE_FROM_EMAIL is unset.
SENDGRID_FROM_EMAIL=you@yourdomain.com

# === Runtime ================================================================
# development | production
NODE_ENV=development
# Port the server listens on (default 5000 if unset).
PORT=5000

# ---------------------------------------------------------------------------
# Replit-only (do NOT set these outside Replit). The app reads them when hosted
# on Replit for the Cartographer dev plugin and the SendGrid connector, and
# falls back to the standard vars above everywhere else:
#   REPL_ID, REPLIT_CONNECTORS_HOSTNAME, REPL_IDENTITY, WEB_REPL_RENEWAL
# These are intentionally NOT required to run the app off Replit.
# ---------------------------------------------------------------------------
